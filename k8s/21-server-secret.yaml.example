# 실제 값은 k8s/21-server-secret.yaml에 넣고 커밋하지 않는다(.gitignore에 이미 등록됨)
apiVersion: v1
kind: Secret
metadata:
  name: omok-server-secret
  namespace: omok
type: Opaque
stringData:
  SESSION_JWT_SECRET: "change-me-to-a-long-random-string"
  # omok-postgres = k8s/11-postgres-service.yaml의 headless Service 이름
  DATABASE_URL: "postgres://<user>:<password>@omok-postgres:5432/omok"
  # GOOGLE_CLIENT_ID는 선택 — 없어도 게스트 모드(공개방/AI)는 정상 동작
