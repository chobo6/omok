# 실제 값은 .env에 넣고 커밋하지 않는다(.gitignore에 이미 등록됨)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
SESSION_JWT_SECRET=change-me-to-a-long-random-string
CLIENT_ORIGIN=http://localhost:3000
# 로컬: docker compose up -d db 로 띄운 Postgres (docs/DB_SCHEMA.md 참고)
DATABASE_URL=postgres://omok:omok@localhost:5432/omok
